@model ProductAttribute
@{ ViewData["Title"] = "Giá trị thuộc tính"; }
<div class="page-header"><div><h1 class="h3 mb-1">@Model.Name</h1><p class="text-muted mb-0">Các giá trị động của thuộc tính</p></div><a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a></div>
<div class="card mb-3"><div class="card-body"><form asp-action="SaveValue" method="post" class="row g-2 align-items-end"><input type="hidden" name="AttributeId" value="@Model.Id" /><div class="col-md-7"><label class="form-label">Giá trị mới</label><input name="Value" required maxlength="100" class="form-control" /></div><div class="col-md-3"><label class="form-label">Thứ tự</label><input name="SortOrder" type="number" value="0" class="form-control" /></div><div class="col-md-2"><button class="btn btn-primary w-100">Thêm</button></div></form></div></div>
<div class="card"><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><partial name="_SortHeader" model='new SortHeaderViewModel { Label = "Giá trị", Column = "value", CurrentSort = (string?)ViewBag.Sort, CurrentDirection = (string?)ViewBag.Direction }' /><partial name="_SortHeader" model='new SortHeaderViewModel { Label = "Thứ tự", Column = "order", CurrentSort = (string?)ViewBag.Sort, CurrentDirection = (string?)ViewBag.Direction }' /><partial name="_SortHeader" model='new SortHeaderViewModel { Label = "Trạng thái", Column = "status", CurrentSort = (string?)ViewBag.Sort, CurrentDirection = (string?)ViewBag.Direction }' /><th></th></tr></thead><tbody>
@if (Model.Values.Count == 0) { <tr><td colspan="4" class="text-center text-muted py-5">Chưa có giá trị.</td></tr> }
@foreach (var value in Model.Values.OrderBy(x => x.SortOrder).ThenBy(x => x.Value))
{
    <tr><td colspan="4"><form asp-action="SaveValue" method="post" class="row g-2 align-items-center"><input type="hidden" name="Id" value="@value.Id" /><input type="hidden" name="AttributeId" value="@Model.Id" /><div class="col-md-5"><input name="Value" value="@value.Value" required maxlength="100" class="form-control form-control-sm" /></div><div class="col-md-2"><input name="SortOrder" value="@value.SortOrder" type="number" class="form-control form-control-sm" /></div><div class="col-md-2"><div class="form-check"><input name="IsActive" value="true" type="checkbox" checked="@value.IsActive" class="form-check-input" /><label class="form-check-label">Đang dùng</label></div></div><div class="col-md-3 text-end"><button class="btn btn-sm btn-outline-primary">Lưu</button> <button type="submit" formaction="@Url.Action("DeleteValue")" formnovalidate name="id" value="@value.Id" class="btn btn-sm btn-outline-danger" data-confirm="Bạn có chắc muốn xóa giá trị thuộc tính này?">Xóa</button><input type="hidden" name="attributeId" value="@Model.Id" /></div></form></td></tr>
}
</tbody></table></div></div>
