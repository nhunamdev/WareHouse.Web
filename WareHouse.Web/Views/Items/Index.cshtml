@model PagedResult<ItemRow>
@{ ViewData["Title"] = "Phân loại sản phẩm"; var products = (IReadOnlyList<Product>)ViewBag.Products; }
<div class="page-header"><div><h1 class="h3 mb-1">Phân loại sản phẩm</h1><p class="text-muted mb-0">Quản lý màu sắc, kích thước, giá và tồn kho</p></div><a asp-action="Edit" class="btn btn-primary">+ Thêm phân loại</a></div>
<form method="get" class="filter-bar row g-2"><div class="col-md-4"><select name="productId" class="form-select"><option value="">Tất cả sản phẩm</option>@foreach (var p in products) { <option value="@p.Id" selected="@(ViewBag.ProductId == p.Id)">@p.Name</option> }</select></div><div class="col-md-5"><input name="keyword" value="@ViewBag.Keyword" class="form-control" placeholder="Tìm sản phẩm..." /></div><div class="col-md-3"><button class="btn btn-outline-primary w-100">Lọc</button></div></form>
<div class="card"><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Sản phẩm</th><th>Thuộc tính</th><th class="money">Giá vốn</th><th class="money">Giá bán</th><th class="quantity">Tổng tồn</th><th>Trạng thái</th><th></th></tr></thead><tbody>
@if (Model.Items.Count == 0) { <tr><td colspan="7" class="text-center text-muted py-5">Chưa có phân loại phù hợp.</td></tr> }
@foreach (var item in Model.Items)
{
<tr><td class="fw-semibold">@item.ProductName</td><td>@(string.IsNullOrEmpty(item.Attributes) ? "—" : item.Attributes)</td><td class="money">@item.CostPrice.ToString("N0")</td><td class="money">@item.SalePrice.ToString("N0")</td><td class="quantity">@item.TotalStock.ToString("N0")</td><td><span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">@(item.IsActive ? "Đang dùng" : "Ngừng dùng")</span></td><td class="text-end text-nowrap"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a> <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" data-confirm="Bạn có chắc muốn xóa phân loại này?"><button class="btn btn-sm btn-outline-danger">Xóa</button></form></td></tr>
}
</tbody></table></div><div class="card-footer bg-white"><partial name="_Pagination" model='new PaginationViewModel { Page = Model.Page, TotalPages = Model.TotalPages, RouteValues = new() { ["keyword"] = (string?)ViewBag.Keyword, ["productId"] = ViewBag.ProductId?.ToString() } }' /></div></div>
