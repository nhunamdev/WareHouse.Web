@model StockDocument
@{
    Layout = null;
    var subtotalAmount = Model.SubtotalAmount > 0 || Model.TotalAmount == 0
        ? Model.SubtotalAmount
        : Model.Details.Sum(x => x.Amount);
    var totalPayable = Model.TotalAmount + Model.PreviousDebtAmount;
    var totalReceived = Model.PaidAmount + Model.PreviousDebtPaidAmount;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Phiếu xuất kho @Model.DocumentNo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { font-family: Arial, sans-serif; }
        .sheet { max-width: 850px; margin: 20px auto; padding: 30px; }
        .invoice-note { margin-top: 22px; padding: 12px 14px; border: 1px solid #d8dee3; border-radius: 8px; background: #f8f9fa; }
        @@media print {
            .d-print-none { display: none; }
            .sheet { margin: 0; max-width: none; padding: 0; }
            tr { break-inside: avoid; }
        }
    </style>
</head>
<body>
<div class="sheet">
    <div class="d-flex justify-content-between d-print-none mb-3">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light">Chi tiết đơn hàng</a>
        <button class="btn btn-primary" onclick="window.print()">In phiếu xuất kho</button>
    </div>
    <div class="text-center mb-4">
        <h1 class="h3">PHIẾU XUẤT KHO</h1>
        <div class="fw-bold">XE ĐẠP TUỆ ANH</div>
    </div>
    <div class="row mb-3">
        <div class="col-6">
            <div><strong>Số:</strong> @Model.DocumentNo</div>
            <div><strong>Ngày:</strong> @Model.DocumentDate.ToString("dd/MM/yyyy HH:mm")</div>
            <div><strong>Kho:</strong> @Model.FromWarehouse?.Name</div>
        </div>
        <div class="col-6">
            <div><strong>Khách hàng:</strong> @Model.Customer?.Name</div>
            <div><strong>Điện thoại:</strong> @(string.IsNullOrWhiteSpace(Model.CustomerPhone) ? Model.Customer?.Phone : Model.CustomerPhone)</div>
            <div><strong>Địa chỉ:</strong> @Model.Customer?.Address</div>
        </div>
    </div>
    <table class="table table-bordered">
        <thead>
        <tr>
            <th>Sản phẩm / Thuộc tính</th>
            <th class="text-end">SL</th>
            <th class="text-end">Đơn giá</th>
            <th class="text-end">Thành tiền</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var line in Model.Details)
        {
            var attrs = WareHouseServices.FormatAttributes(line.Item.ItemAttributes);
            <tr>
                <td>
                    @line.Item.Product.Name
                    @if (!string.IsNullOrEmpty(attrs))
                    {
                        <small class="d-block">@attrs</small>
                    }
                </td>
                <td class="text-end">@line.Quantity.ToString("N0")</td>
                <td class="text-end">@line.Price.ToString("N0")</td>
                <td class="text-end">@line.Amount.ToString("N0")</td>
            </tr>
        }
        </tbody>
    </table>
    <div class="row justify-content-end">
        <div class="col-sm-6">
            <table class="table table-sm">
                <tr><th>Tổng tiền đơn hàng</th><td class="text-end">@subtotalAmount.ToString("N0")</td></tr>
                <tr><th>Chiết khấu</th><td class="text-end">@Model.DiscountAmount.ToString("N0")</td></tr>
                <tr><th>Nợ cũ</th><td class="text-end">@Model.PreviousDebtAmount.ToString("N0")</td></tr>
                <tr><th>Tổng phải thanh toán</th><td class="text-end fw-bold">@totalPayable.ToString("N0")</td></tr>
                @if (Model.Status == DocumentStatus.Completed)
                {
                    <tr><th>Khách đã thanh toán</th><td class="text-end">@totalReceived.ToString("N0")</td></tr>
                    <tr><th>Công nợ hiện tại của khách</th><td class="text-end">@Math.Max(0, Model.Customer?.Debt ?? 0).ToString("N0")</td></tr>
                }
                else
                {
                    <tr><th>Trạng thái</th><td class="text-end">Chờ hoàn thành</td></tr>
                }
            </table>
        </div>
    </div>
    <p><strong>Ghi chú:</strong> @Model.Remark</p>
    <div class="invoice-note">
        <strong>Lưu ý:</strong> Xử lý lỗi, khiếu nại trong vòng 24 giờ. Rất mong sự hợp tác của quý khách.
    </div>
    <div class="row text-center mt-5">
        <div class="col-6">
            <strong>Người mua hàng</strong>
            <div class="text-muted">(Ký, ghi rõ họ tên)</div>
        </div>
        <div class="col-6">
            <strong>Người bán hàng</strong>
            <div class="text-muted">@(Model.CreatedBy ?? "System")</div>
        </div>
    </div>
</div>
@if ((bool?)ViewBag.AutoPrint == true)
{
    <script>window.addEventListener('load', () => window.print());</script>
}
</body>
</html>
