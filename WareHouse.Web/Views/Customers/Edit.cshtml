@model Customer
@{ ViewData["Title"] = Model.Id == 0 ? "Thêm khách hàng" : "Sửa khách hàng"; }
<div class="page-header"><h1 class="h3 mb-0">@ViewData["Title"]</h1><a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a></div>
<div class="card"><div class="card-body"><form method="post" class="row g-3"><input asp-for="Id" type="hidden" /><input asp-for="Code" type="hidden" /><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="col-md-8"><label asp-for="Name" class="form-label">Tên khách hàng</label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div><div class="col-md-4"><label asp-for="CustomerType" class="form-label">Loại khách</label><select asp-for="CustomerType" class="form-select"><option value="Retail">Khách lẻ</option><option value="Dealer">Đại lý</option></select></div><div class="col-md-4"><label asp-for="Phone" class="form-label">Điện thoại</label><input asp-for="Phone" class="form-control" /></div><div class="col-md-4"><label asp-for="TaxCode" class="form-label">Mã số thuế</label><input asp-for="TaxCode" class="form-control" /></div><div class="col-12"><label asp-for="Address" class="form-label">Địa chỉ</label><input asp-for="Address" class="form-control" /></div>@if (Model.Id > 0) { <div class="col-12"><div class="form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Đang hoạt động</label></div></div> }<div class="col-12"><button class="btn btn-primary">Lưu khách hàng</button> <a asp-action="Index" class="btn btn-light">Hủy</a></div></form></div></div>
@if (Model.Id > 0) { <partial name="_AuditInfo" model="Model" /> }
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
