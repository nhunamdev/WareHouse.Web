@model StockDocument
@{
    var isStockOperation = Model.DocumentType is StockDocumentType.Import or StockDocumentType.Export or StockDocumentType.Transfer;
    var isImport = Model.DocumentType == StockDocumentType.Import;
    var isExport = Model.DocumentType == StockDocumentType.Export;
    var isTransfer = Model.DocumentType == StockDocumentType.Transfer;
    string title = Model.DocumentType switch
    {
        StockDocumentType.Import => "Chi tiết phiếu nhập kho",
        StockDocumentType.Export => "Chi tiết phiếu xuất kho",
        StockDocumentType.Transfer => "Chi tiết phiếu chuyển kho",
        StockDocumentType.Return => "Phiếu trả hàng",
        _ => "Phiếu điều chỉnh"
    };
    var badge = Model.Status == DocumentStatus.Completed ? "bg-success" : Model.Status == DocumentStatus.Cancelled ? "bg-danger" : "bg-secondary";
    var operationDateLabel = isImport ? "Ngày nhập" : isExport ? "Ngày xuất" : "Ngày chuyển";
    var operationPersonLabel = isImport ? "Người nhập" : isExport ? "Người xuất" : "Người chuyển";
    var operationIntro = isImport
        ? $"Danh sách hàng đã được ghi nhận vào {Model.ToWarehouse?.Name ?? "kho"}"
        : isExport
            ? $"Danh sách hàng đã được lấy khỏi {Model.FromWarehouse?.Name ?? "kho"}"
            : $"Danh sách hàng chuyển từ {Model.FromWarehouse?.Name ?? "kho nguồn"} sang {Model.ToWarehouse?.Name ?? "kho đích"}";
    var completeLabel = isImport ? "Hoàn tất phiếu nhập kho" : isExport ? "Hoàn tất phiếu xuất kho" : "Hoàn tất phiếu chuyển kho";
    var cancelLabel = isImport ? "Hủy phiếu nhập" : isExport ? "Hủy phiếu xuất" : "Hủy phiếu chuyển";
    var completeConfirmation = isImport
        ? "Hoàn tất phiếu nhập kho này và cộng hàng vào tồn kho?"
        : isExport
            ? "Hoàn tất phiếu xuất kho này và trừ hàng khỏi tồn kho?"
            : "Hoàn tất phiếu chuyển kho này và chuyển tồn từ kho nguồn sang kho đích?";
    var cancelConfirmation = isImport
        ? "Hủy phiếu nhập kho này? Số lượng đã nhập sẽ bị trừ khỏi tồn kho."
        : isExport
            ? "Hủy phiếu xuất kho này? Số lượng đã xuất sẽ được cộng trả lại kho."
            : "Hủy phiếu chuyển kho này? Tồn kho sẽ được chuyển ngược về kho nguồn.";
    var cancelledMessage = isImport
        ? "Lần nhập kho này đã bị hủy và số lượng đã được hoàn khỏi tồn kho."
        : isExport
            ? "Lần xuất kho này đã bị hủy và số lượng đã được cộng trả lại kho."
            : "Lần chuyển kho này đã bị hủy và số lượng đã được chuyển trả về kho nguồn.";
    var quantityClass = isImport ? "text-success" : isExport ? "text-danger" : "text-primary";
    var showOperationValue = !isTransfer;
    ViewData["Title"] = isStockOperation ? title : Model.DocumentNo;
}

@if (isStockOperation)
{
    <div class="page-header">
        <div>
            <h1 class="h3 mb-1">@title</h1>
            <p class="text-muted mb-0">@operationIntro</p>
        </div>
        <div>
            @if (Model.Status == DocumentStatus.Draft)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" asp-route-type="@Model.DocumentType" class="btn btn-outline-primary">Sửa</a>
                <form asp-action="Complete" asp-route-id="@Model.Id" method="post" class="d-inline"
                      data-confirm="@completeConfirmation">
                    <button class="btn btn-success">@completeLabel</button>
                </form>
            }
            @if (Model.Status == DocumentStatus.Completed)
            {
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline"
                      data-confirm="@cancelConfirmation">
                    <button class="btn btn-outline-danger">@cancelLabel</button>
                </form>
            }
            <a asp-action="Index" asp-route-type="@Model.DocumentType" class="btn btn-light">Danh sách</a>
        </div>
    </div>

    @if (Model.Status == DocumentStatus.Cancelled)
    {
        <div class="alert alert-danger">@cancelledMessage</div>
    }

    <div class="card mb-3 import-detail-summary">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-lg-3 col-md-4 col-6">
                    <small class="text-muted">@operationDateLabel</small>
                    <div class="fw-semibold">@Model.DocumentDate.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                @if (isExport || isTransfer)
                {
                    <div class="col-lg-3 col-md-4 col-6">
                        <small class="text-muted">@(isTransfer ? "Kho nguồn" : "Kho xuất")</small>
                        <div class="fw-semibold">@(Model.FromWarehouse?.Name ?? "—")</div>
                    </div>
                }
                @if (isImport || isTransfer)
                {
                    <div class="col-lg-3 col-md-4 col-6">
                        <small class="text-muted">@(isImport ? "Kho nhập" : "Kho đích")</small>
                        <div class="fw-semibold">@(Model.ToWarehouse?.Name ?? "—")</div>
                    </div>
                }
                <div class="col-lg-3 col-md-4 col-6">
                    <small class="text-muted">@operationPersonLabel</small>
                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.CreatedBy) ? "Hệ thống" : Model.CreatedBy)</div>
                </div>
                <div class="col-lg-3 col-md-4 col-6">
                    <small class="text-muted">Tổng số lượng</small>
                    <div class="fw-semibold @quantityClass">@Model.Details.Sum(x => x.Quantity).ToString("N0")</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Remark))
                {
                    <div class="col-12">
                        <small class="text-muted">@(isExport ? "Lý do / ghi chú" : "Ghi chú")</small>
                        <div>@Model.Remark</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table mb-0 import-detail-table">
                <thead>
                    <tr>
                            <th>Sản phẩm / phân loại</th>
                        <th class="quantity">Số lượng</th>
                        @if (showOperationValue)
                        {
                            <th class="money">@(isImport ? "Giá nhập" : "Đơn giá")</th>
                            <th class="money">Thành tiền</th>
                        }
                    </tr>
                </thead>
                <tbody>
                @foreach (var line in Model.Details.OrderBy(x => x.Item.Product.Name).ThenBy(x => x.ItemId))
                {
                    var attributes = WareHouseServices.FormatAttributes(line.Item.ItemAttributes);
                    <tr>
                        <td>
                            <div class="import-product-cell">
                                <strong>@line.Item.Product.Name</strong>
                                @if (!string.IsNullOrWhiteSpace(attributes))
                                {
                                    <small>@attributes</small>
                                }
                            </div>
                        </td>
                        <td class="quantity fw-bold @quantityClass">@line.Quantity.ToString("N0")</td>
                        @if (showOperationValue)
                        {
                            <td class="money">@line.Price.ToString("N0") <span class="currency-suffix">đ</span></td>
                            <td class="money fw-semibold">@line.Amount.ToString("N0") <span class="currency-suffix">đ</span></td>
                        }
                    </tr>
                }
                </tbody>
                @if (showOperationValue)
                {
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">@(isImport ? "Tổng tiền nhập" : "Tổng giá trị xuất")</th>
                            <th class="money document-total">@Model.TotalAmount.ToString("N0") <span class="currency-suffix">đ</span></th>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
}
else
{
    <partial name="_AuditInfo" model="Model" />
    <div class="page-header">
        <div>
            <h1 class="h3 mb-1">@title @Model.DocumentNo</h1>
            <span class="badge @badge">@Model.Status</span>
        </div>
        <div>
            @if (Model.Status == DocumentStatus.Draft)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" asp-route-type="@Model.DocumentType" class="btn btn-outline-primary">Sửa nháp</a>
                <form asp-action="Complete" asp-route-id="@Model.Id" method="post" class="d-inline" data-confirm="Hoàn tất chứng từ và cập nhật tồn kho?">
                    <button class="btn btn-success">Hoàn tất</button>
                </form>
            }
            @if (Model.Status != DocumentStatus.Cancelled)
            {
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline" data-confirm="Hủy chứng từ và đảo nghiệp vụ tồn kho?">
                    <button class="btn btn-danger">Hủy chứng từ</button>
                </form>
            }
            <a asp-action="Index" asp-route-type="@Model.DocumentType" class="btn btn-light">Danh sách</a>
        </div>
    </div>
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3"><small class="text-muted">Ngày chứng từ</small><div>@Model.DocumentDate.ToString("dd/MM/yyyy HH:mm")</div></div>
                <div class="col-md-3"><small class="text-muted">Kho nguồn</small><div>@(Model.FromWarehouse?.Name ?? "—")</div></div>
                <div class="col-md-3"><small class="text-muted">Kho đích</small><div>@(Model.ToWarehouse?.Name ?? "—")</div></div>
                <div class="col-md-3"><small class="text-muted">Khách hàng</small><div>@(Model.Customer?.Name ?? "—")</div></div>
                <div class="col-12"><small class="text-muted">Ghi chú</small><div>@(Model.Remark ?? "—")</div></div>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead><tr><th>Sản phẩm</th><th>Thuộc tính</th><th class="quantity">Số lượng</th><th class="money">Đơn giá</th><th class="money">Thành tiền</th></tr></thead>
                <tbody>
                @foreach (var line in Model.Details)
                {
                    <tr>
                        <td class="fw-semibold">@line.Item.Product.Name</td>
                        <td>@(WareHouseServices.FormatAttributes(line.Item.ItemAttributes) is { Length: > 0 } attrs ? attrs : "—")</td>
                        <td class="quantity">@line.Quantity.ToString("N0")</td>
                        <td class="money">@line.Price.ToString("N0")</td>
                        <td class="money">@line.Amount.ToString("N0")</td>
                    </tr>
                }
                </tbody>
                <tfoot><tr><th colspan="4" class="text-end">Tổng tiền</th><th class="money document-total">@Model.TotalAmount.ToString("N0")</th></tr></tfoot>
            </table>
        </div>
    </div>
}
