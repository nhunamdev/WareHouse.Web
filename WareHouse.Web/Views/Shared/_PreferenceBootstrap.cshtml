<script>
(() => {
    const root = document.documentElement;
    let theme = "light";
    let fontSize = "normal";

    try {
        const savedTheme = localStorage.getItem("warehouse.theme");
        const savedFontSize = localStorage.getItem("warehouse.fontSize");
        if (savedTheme === "dark" || savedTheme === "light") theme = savedTheme;
        if (["small", "normal", "large"].includes(savedFontSize)) fontSize = savedFontSize;
    } catch {
        // The interface still works with default preferences when storage is unavailable.
    }

    root.dataset.theme = theme;
    root.dataset.fontSize = fontSize;
    root.style.colorScheme = theme;
})();
</script>
