@inject Microsoft.Extensions.Options.IOptions<StoreContactOptions> ContactOptions
@{
    var contact = ContactOptions.Value;
    var currentPath = Context.Request.Path.Value?.TrimEnd('/') ?? string.Empty;
    var currentRequest = $"{Context.Request.Path}{Context.Request.QueryString}";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var currentCulture = StoreCulture.CurrentCode;
    var unprefixedPath = StoreCulture.ForCulture(currentPath, "vi").TrimEnd('/');
    string LanguageUrl(string culture) => $"/language/{culture}?returnUrl={Uri.EscapeDataString(currentRequest)}";
}
<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["MetaDescription"] ?? T["HomeMeta"])" />
    @if (ViewData["Robots"] is string robots && !string.IsNullOrWhiteSpace(robots))
    {
        <meta name="robots" content="@robots" />
    }
    <title>@(ViewData["Title"] ?? "Xe đạp Tuệ Anh")</title>
    <link rel="icon" type="image/png" href="~/themes/default/images/ic_logo_tueanh.png" />
    <link rel="alternate" hreflang="vi" href="@(baseUrl + StoreCulture.ForCulture(currentPath, "vi"))" />
    <link rel="alternate" hreflang="en" href="@(baseUrl + StoreCulture.ForCulture(currentPath, "en"))" />
    <link rel="alternate" hreflang="de" href="@(baseUrl + StoreCulture.ForCulture(currentPath, "de"))" />
    <link rel="alternate" hreflang="x-default" href="@(baseUrl + StoreCulture.ForCulture(currentPath, "vi"))" />
    @await RenderSectionAsync("Head", required: false)
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="store-header sticky-top">
        <nav class="navbar navbar-expand-lg navbar-light py-2">
            <div class="container-xxl">
                <a class="brand d-flex align-items-center gap-2 text-decoration-none" href="@StoreCulture.Path("/")">
                    <img class="brand-logo" src="~/themes/default/images/ic_logo_tueanh.png" width="48" height="48" alt="Xe đạp Tuệ Anh" />
                    <span><strong>Xe đạp Tuệ Anh</strong><small>ĐI ÊM · SỐNG KHỎE</small></span>
                </a>
                <form class="site-search mobile-site-search d-lg-none" method="get" action="@StoreCulture.Path("/tim-kiem")" role="search" data-site-search data-suggestions-url="@StoreCulture.Path("/api/tim-kiem-goi-y")">
                    <svg class="site-search-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path></svg>
                    <input type="search" name="q" value="@(Context.Request.Query["q"].ToString())"
                           placeholder="@T["SearchPlaceholder"]" aria-label="@T["Search"]"
                           autocomplete="off" aria-autocomplete="list" aria-expanded="false" />
                    <button type="submit" aria-label="@T["Search"]">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
                    </button>
                    <div class="search-suggestions" data-search-suggestions role="listbox" hidden></div>
                </form>
                <button class="navbar-toggler border-0 shadow-none" type="button"
                        data-bs-toggle="offcanvas" data-bs-target="#storeNav"
                        aria-controls="storeNav" aria-label="Mở menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="offcanvas-lg offcanvas-end store-nav-panel" tabindex="-1" id="storeNav" aria-labelledby="storeNavLabel">
                    <div class="offcanvas-header d-lg-none">
                        <a class="brand mobile-nav-brand d-flex align-items-center gap-2 text-decoration-none" href="@StoreCulture.Path("/")">
                            <img class="brand-logo" src="~/themes/default/images/ic_logo_tueanh.png" width="48" height="48" alt="Xe đạp Tuệ Anh" />
                            <span id="storeNavLabel"><strong>Xe đạp Tuệ Anh</strong><small>@T["Products"]</small></span>
                        </a>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" data-mobile-nav-close aria-label="Close"></button>
                    </div>
                    <div class="offcanvas-body">
                    <ul class="navbar-nav mx-lg-auto gap-lg-2">
                        @foreach (var category in StoreCategories.All)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(string.Equals(currentPath, category.Url, StringComparison.OrdinalIgnoreCase) ? "active" : null)"
                                   href="@category.Url">@category.DisplayName</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link @(string.Equals(unprefixedPath, "/ve-chung-toi", StringComparison.OrdinalIgnoreCase) ? "active" : null)"
                               href="@StoreCulture.Path("/ve-chung-toi")">@T["AboutUs"]</a>
                        </li>
                    </ul>
                    <div class="store-nav-actions d-flex align-items-center gap-2">
                        <form class="site-search" method="get" action="@StoreCulture.Path("/tim-kiem")" role="search" data-site-search data-suggestions-url="@StoreCulture.Path("/api/tim-kiem-goi-y")">
                            <svg class="site-search-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path></svg>
                            <input type="search" name="q" value="@(Context.Request.Query["q"].ToString())"
                                   placeholder="@T["SearchPlaceholder"]" aria-label="@T["Search"]"
                                   autocomplete="off" aria-autocomplete="list" aria-expanded="false" />
                            <button type="submit" aria-label="@T["Search"]">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
                            </button>
                            <div class="search-suggestions" data-search-suggestions role="listbox" hidden></div>
                        </form>
                        <div class="language-switcher" aria-label="@T["Language"]">
                            <a href="@LanguageUrl("vi")" class="@(currentCulture == "vi" ? "active" : null)" lang="vi" hreflang="vi">VI</a>
                            <a href="@LanguageUrl("en")" class="@(currentCulture == "en" ? "active" : null)" lang="en" hreflang="en">EN</a>
                            <a href="@LanguageUrl("de")" class="@(currentCulture == "de" ? "active" : null)" lang="de" hreflang="de">DE</a>
                        </div>
                        <a class="btn btn-dark rounded-pill px-3" href="@contact.TelephoneUrl">@T["Call", contact.PhoneLabel]</a>
                    </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>@RenderBody()</main>

    <footer class="store-footer" id="contact">
        <div class="container-xxl py-4">
            <div class="row g-4 align-items-start">
                <div class="col-lg-6">
                    <a class="brand d-inline-flex align-items-center gap-2 text-decoration-none mb-3" href="@StoreCulture.Path("/")">
                        <img class="brand-logo" src="~/themes/default/images/ic_logo_tueanh.png" width="54" height="54" alt="Xe đạp Tuệ Anh" />
                        <span><strong>Xe đạp Tuệ Anh</strong><small>CHẤT LƯỢNG · UY TÍN · ĐỒNG HÀNH</small></span>
                    </a>
                    <p class="footer-copy mb-0">@T["FooterCopy"]</p>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <h6>@T["Contact"]</h6>
                    <a href="@contact.TelephoneUrl">@contact.PhoneLabel</a>
                    <a href="@contact.ZaloAddress" target="_blank" rel="noopener">@T["MessageZalo"]</a>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <h6>@T["Products"]</h6>
                    <a href="@(StoreCulture.Path("/") + "#catalog")">@T["ViewSellingBikes"]</a>
                </div>
            </div>
            <div class="footer-bottom mt-4 pt-3"><span>© 2026 Xe đạp Tuệ Anh</span><span>@T["FooterQuality"]</span></div>
        </div>
    </footer>

    <aside class="floating-contact" aria-label="@T["QuickContact"]">
        <a class="floating-contact-button is-phone" href="@contact.TelephoneUrl" aria-label="@T["Call", contact.PhoneLabel]" title="@T["Call", contact.PhoneLabel]">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.2 1.3.5 2.7.8 4.2.8.7 0 1.2.5 1.2 1.2v3.8c0 .7-.5 1.2-1.2 1.2C10.4 22 2 13.6 2 3.2 2 2.5 2.5 2 3.2 2H7c.7 0 1.2.5 1.2 1.2 0 1.5.3 2.9.8 4.2.1.4.1.9-.2 1.2l-2.2 2.2Z" /></svg>
        </a>
        <a class="floating-contact-button is-zalo" href="@contact.ZaloAddress" target="_blank" rel="noopener" aria-label="@T["MessageZalo"]" title="@T["MessageZalo"]">Zalo</a>
        <button class="floating-contact-button is-top" type="button" data-scroll-top aria-label="@T["BackToTop"]" title="@T["BackToTop"]">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 15 6-6 6 6" /></svg>
        </button>
    </aside>

    <script>
        window.storeI18n = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
        {
            locale = StoreCulture.CultureName(currentCulture),
            notSelected = T["NotSelected"],
            chooseVariant = T["ChooseVariant"],
            standardModel = T["StandardModel"],
            selectedVariantInStock = T["SelectedVariantInStock"],
            selectedVariantPreOrder = T["SelectedVariantPreOrder"],
            selectedModelPreOrder = T["SelectedModelPreOrder"],
            stockOnly = T["StockOnly"],
            noSuggestions = T["NoSuggestions"],
            searching = T["Searching"]
        }))
    </script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
