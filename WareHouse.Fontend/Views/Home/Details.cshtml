@model ProductDetailViewModel
@inject Microsoft.Extensions.Options.IOptions<StoreContactOptions> ContactOptions
@{
    var cover = Model.Images.FirstOrDefault();
    var firstVariant = Model.Variants.FirstOrDefault();
    var displayDescription = !string.IsNullOrWhiteSpace(Model.ShortDescription)
        ? Model.ShortDescription
        : (!string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : null);
    var metaTitle = !string.IsNullOrWhiteSpace(Model.SeoTitle) ? Model.SeoTitle : Model.Name;
    var metaDescription = !string.IsNullOrWhiteSpace(Model.SeoDescription)
        ? Model.SeoDescription
        : displayDescription ?? T["ProductMetaFallback", Model.Name];
    var hasRichContent = !string.IsNullOrWhiteSpace(Model.DetailContent)
        || (!string.IsNullOrWhiteSpace(Model.Description)
            && !string.Equals(Model.Description, displayDescription, StringComparison.Ordinal));
    var stockUnit = string.IsNullOrWhiteSpace(Model.Unit) ? string.Empty : $" {Model.Unit.ToLowerInvariant()}";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var canonicalUrl = baseUrl + Model.ProductUrl;
    var absoluteCover = cover is null ? $"{baseUrl}/themes/default/images/ic_logo_tueanh.png" : (cover.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? cover : baseUrl + cover);
    var variantJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Variants.Select(variant => new
        {
            variant.Id,
            variant.Label,
            variant.Stock,
            variant.ImageUrl,
            variant.AttributeValueIds
        }),
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
    var schema = new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "Product",
        ["name"] = Model.Name,
        ["description"] = metaDescription,
        ["sku"] = $"PRODUCT-{Model.Id}",
        ["brand"] = new Dictionary<string, object?> { ["@type"] = "Brand", ["name"] = "Xe đạp Tuệ Anh" }
    };
    if (Model.Images.Count > 0)
        schema["image"] = Model.Images.Select(image => image.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? image : baseUrl + image).ToArray();
    if (!string.IsNullOrWhiteSpace(Model.Category))
        schema["category"] = Model.Category;
    var schemaJson = System.Text.Json.JsonSerializer.Serialize(schema);
    ViewData["Title"] = metaTitle;
    ViewData["MetaDescription"] = metaDescription;
    var contact = ContactOptions.Value;
}

@section Head {
    <link rel="canonical" href="@canonicalUrl" />
    @if (!string.IsNullOrWhiteSpace(Model.SeoKeywords)) { <meta name="keywords" content="@Model.SeoKeywords" /> }
    <meta property="og:type" content="product" />
    <meta property="og:site_name" content="Xe đạp Tuệ Anh" />
    <meta property="og:title" content="@metaTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:image" content="@absoluteCover" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@metaTitle" />
    <meta name="twitter:description" content="@metaDescription" />
    <meta name="twitter:image" content="@absoluteCover" />
    <script type="application/ld+json">@Html.Raw(schemaJson)</script>
}

<section class="detail-section">
    <div class="container-xxl">
        <nav class="breadcrumb-store"><a href="@StoreCulture.Path("/")">@T["Home"]</a><span>/</span>@if (!string.IsNullOrWhiteSpace(Model.Category)){<a href="@StoreCategories.UrlFor(Model.Category)">@Model.Category</a><span>/</span>}<strong>@Model.Name</strong></nav>
        <div class="row g-4 align-items-start detail-main-row">
            <div class="col-lg-7">
                <div class="detail-gallery">
                    <div class="detail-cover" data-detail-cover>@if (cover is not null){<img src="@cover" alt="@Model.Name" />}else{<div class="product-placeholder"><span>TA</span></div>}</div>
                    @if (Model.Images.Count > 1){<div class="detail-thumbs">@foreach (var image in Model.Images){<button type="button" class="detail-thumb @(image == cover ? "active" : "")" data-gallery-thumb="@image"><img src="@image" alt="@T["ProductImage", Model.Name]" /></button>}</div>}
                </div>
            </div>
            <div class="col-lg-5">
                <div class="detail-content">
                    @if (!string.IsNullOrWhiteSpace(Model.Category))
                    {
                        <span class="eyebrow">@Model.Category</span>
                    }
                    <h1>@Model.Name</h1>
                    @if (!string.IsNullOrWhiteSpace(displayDescription))
                    {
                        <p class="detail-description">@displayDescription</p>
                    }
                    <div class="detail-price" data-detail-price>@T["Consult"]</div>
                    @if (Model.Variants.Count > 0)
                    {
                        <div class="stock-summary"><span class="stock-dot"></span><span data-detail-stock>@(Model.TotalStock > 0 ? T["StockAvailable", Model.TotalStock.ToString("N0"), stockUnit.Trim()] : T["CanPreOrder"])</span></div>
                    }
                    @if (Model.AttributeGroups.Count > 0)
                    {
                        <hr class="detail-divider" />
                        <div class="combination-picker" data-combination-picker>
                            @foreach (var group in Model.AttributeGroups)
                            {
                                <div class="attribute-group" data-attribute-group="@group.Id"><div class="attribute-heading"><strong>@group.Name</strong><small data-selected-label>@T["NotSelected"]</small></div><div class="attribute-choices">@foreach (var choice in group.Choices){<button type="button" class="attribute-choice @(choice.ColorHex is not null ? "is-color" : "")" data-group-id="@group.Id" data-value-id="@choice.Id" data-value-name="@choice.Name" aria-pressed="false">@if (choice.ColorHex is not null){<i style="--swatch:@choice.ColorHex"></i>}<span>@choice.Name</span><b>✓</b></button>}</div></div>
                            }
                        </div>
                        <p class="combination-message" data-combination-message>@T["ChooseVariant"]</p>
                    }
                    else if (firstVariant is not null)
                    {
                        <hr class="detail-divider" />
                        <div class="single-variant"><span>@T["StandardModel"]</span><strong>@T["Contact"]</strong></div>
                    }
                    <div class="detail-contact-actions mt-4">
                        <a class="btn btn-dark btn-lg rounded-pill" href="@contact.TelephoneUrl">@T["Call", contact.PhoneLabel]</a>
                        <a class="btn btn-outline-success btn-lg rounded-pill" href="@contact.ZaloAddress" target="_blank" rel="noopener">@T["MessageZalo"]</a>
                    </div>
                    <div class="detail-trust"><span>✓ @T["CheckBeforeDelivery"]</span><span>✓ @T["AfterSalesSupport"]</span></div>
                </div>
            </div>
        </div>
    </div>
</section>
<script type="application/json" id="productVariants">@Html.Raw(variantJson)</script>

@if (hasRichContent)
{
    <section class="spec-section">
        <div class="container-fluid product-detail-container">
            <article class="product-detail-article">
                <div class="product-rich-content">
                    @if (!string.IsNullOrWhiteSpace(Model.DetailContent))
                    {
                        @Html.Raw(Model.DetailContent)
                    }
                    else if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <p>@Model.Description</p>
                    }
                </div>
            </article>
        </div>
    </section>
}
