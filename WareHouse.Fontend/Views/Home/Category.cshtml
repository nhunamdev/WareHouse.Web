@model StoreCategoryViewModel
@{
    ViewData["Title"] = $"{Model.Name} | Xe đạp Tuệ Anh";
    ViewData["MetaDescription"] = T["CategoryMeta", Model.Name.ToLowerInvariant()];
    var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Model.Url}";
}

@section Head {
    <link rel="canonical" href="@canonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Xe đạp Tuệ Anh" />
    <meta property="og:title" content="@ViewData["Title"]" />
    <meta property="og:description" content="@ViewData["MetaDescription"]" />
    <meta property="og:url" content="@canonicalUrl" />
}

<section class="category-page">
    <div class="container-xxl">
        <nav class="breadcrumb-store"><a href="@StoreCulture.Path("/")">@T["Home"]</a><span>/</span><strong>@Model.Name</strong></nav>
        <div class="category-page-header">
            <h1>@Model.Name</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Query))
            {
                <a class="clear-filter" href="@Model.Url">@T["ClearFilter", Model.Query]</a>
            }
        </div>

        @if (Model.Products.Count == 0)
        {
            <div class="empty-state">
                <h3>@T["NoProducts"]</h3>
                @if (!string.IsNullOrWhiteSpace(Model.Query))
                {
                    <p>@T["NoMatchingProducts", Model.Query]</p>
                    <a class="btn btn-dark rounded-pill" href="@Model.Url">@T["ViewAllCategory", Model.Name.ToLowerInvariant()]</a>
                }
                else
                {
                    <p>@T["CategoryUpdating"]</p>
                }
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in Model.Products)
                {
                    <div class="col-sm-6 col-lg-4 col-xxl-3"><partial name="_ProductCard" model="product" /></div>
                }
            </div>
        }
    </div>
</section>
