@model StoreHomeViewModel
@inject Microsoft.Extensions.Options.IOptions<StoreContactOptions> ContactOptions
@{
    ViewData["Title"] = T["HomeTitle"];
    ViewData["MetaDescription"] = T["HomeMeta"];
    var siteBaseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var homeCanonical = $"{siteBaseUrl}{StoreCulture.Path("/")}";
    var contact = ContactOptions.Value;
}

@section Head {
    <link rel="canonical" href="@homeCanonical" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Xe đạp Tuệ Anh" />
    <meta property="og:title" content="@T["HomeTitle"]" />
    <meta property="og:description" content="@T["HomeMeta"]" />
    <meta property="og:url" content="@homeCanonical" />
    <meta property="og:image" content="@(siteBaseUrl + "/themes/default/images/ic_logo_tueanh.png")" />
    <meta name="twitter:card" content="summary_large_image" />
}

<section class="hero-section">
    <div class="container-xxl">
        <div class="hero-panel hero-carousel-shell">
            @if (Model.Banners.Count > 0)
            {
                <div id="storeHeroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000" data-bs-wrap="true" data-bs-pause="hover" data-bs-touch="true">
                    <div class="carousel-inner">
                        @for (var bannerIndex = 0; bannerIndex < Model.Banners.Count; bannerIndex++)
                        {
                            var banner = Model.Banners[bannerIndex];
                            <div class="carousel-item @(bannerIndex == 0 ? "active" : null)">
                                <div class="row align-items-center g-4">
                                    <div class="col-lg-5">
                                        <div class="eyebrow"><span></span> Xe đạp Tuệ Anh</div>
                                        @if (bannerIndex == 0)
                                        {
                                            <h1 class="hero-title">@banner.Title</h1>
                                        }
                                        else
                                        {
                                            <h2 class="hero-title">@banner.Title</h2>
                                        }
                                        <p class="hero-lead">@T["HeroLead"]</p>
                                        <div class="d-flex flex-wrap gap-2">
                                            <a class="btn btn-dark btn-lg rounded-pill px-4" href="@contact.TelephoneUrl">@T["Call", contact.PhoneLabel]</a>
                                            @if (banner.HasLink)
                                            {
                                                <a class="btn btn-light btn-lg rounded-pill px-4" href="@banner.Url" target="_blank" rel="noopener noreferrer">@T["ViewProduct"]</a>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-lg-7">
                                        <div class="hero-product">
                                            @if (banner.HasLink)
                                            {
                                                <a class="hero-banner-link" href="@banner.Url" target="_blank" rel="noopener noreferrer" aria-label="@banner.Title">
                                                    <img class="hero-banner-image" src="@banner.ImageUrl" alt="@banner.Title" fetchpriority="@(bannerIndex == 0 ? "high" : "auto")" decoding="async" />
                                                </a>
                                            }
                                            else
                                            {
                                                <img class="hero-banner-image" src="@banner.ImageUrl" alt="@banner.Title" fetchpriority="@(bannerIndex == 0 ? "high" : "auto")" decoding="async" />
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    @if (Model.Banners.Count > 1)
                    {
                        <div class="hero-carousel-controls">
                            <button class="hero-slide-button" type="button" data-bs-target="#storeHeroCarousel" data-bs-slide="prev" aria-label="@T["PreviousBanner"]"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m14.5 6-6 6 6 6" /></svg></button>
                            <button class="hero-slide-button" type="button" data-bs-target="#storeHeroCarousel" data-bs-slide="next" aria-label="@T["NextBanner"]"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9.5 6 6 6-6 6" /></svg></button>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="row align-items-center g-4">
                    <div class="col-lg-5">
                        <div class="eyebrow"><span></span> Xe đạp Tuệ Anh</div>
                        <h1 class="hero-title">@T["ChooseBikeTitle"]</h1>
                        <p class="hero-lead">@T["HeroLead"]</p>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-dark btn-lg rounded-pill px-4" href="@contact.TelephoneUrl">@T["Call", contact.PhoneLabel]</a>
                        </div>
                    </div>
                    <div class="col-lg-7"><div class="hero-product"><div class="hero-bike-placeholder"><span>TA</span></div></div></div>
                </div>
            }
        </div>
    </div>
</section>

@if (Model.CategorySections.Count > 0)
{
    <section class="home-catalog" id="catalog">
        <div class="container-xxl">
            @foreach (var categorySection in Model.CategorySections)
            {
                <section class="category-showcase">
                    <div class="category-showcase-heading">
                        <h2>@categorySection.Name</h2>
                        <a class="category-more" href="@categorySection.Url">
                            <span>@T["ViewMore"]</span>
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
                        </a>
                    </div>
                    <div class="row g-4">
                        @foreach (var product in categorySection.Products)
                        {
                            <div class="col-sm-6 col-lg-4 col-xxl-3"><partial name="_ProductCard" model="product" /></div>
                        }
                    </div>
                </section>
            }
        </div>
    </section>
}
